{
  "name": "dakwah",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "vite build && bun build src/index.ts --target=bun --outdir=dist/server",
    "start": "NODE_ENV=production bun dist/server/index.js",
    "test": "bun test",
    "qa:ui": "bun scripts/ui-smoke.ts",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.583.0",
    "@aws-sdk/s3-request-presigner": "^3.583.0",
    "@hono/node-server": "^1.11.1",
    "@hono/zod-validator": "^0.2.1",
    "@vitejs/plugin-react": "^4.2.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "docx": "^8.5.0",
    "drizzle-orm": "^0.31.2",
    "hono": "^4.4.4",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.7",
    "openai": "^4.47.1",
    "pdfkit": "^0.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.3",
    "@types/pdfkit": "^0.13.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.22.7",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
