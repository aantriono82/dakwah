APP_IMAGE=ghcr.io/aantriono82/dakwah:latest
APP_PUBLIC_URL=https://dakwah.example.com
CORS_ORIGINS=https://dakwah.example.com
AUTH_COOKIE_SECURE=true

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=5500
OPENAI_TIMEOUT_MS=30000

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

RESEND_API_KEY=
EMAIL_FROM=Dakwah <noreply@example.com>

SEED_ADMIN_PASSWORD=change-this-admin-password
SEED_USER_PASSWORD=change-this-user-password

S3_ACCESS_KEY_ID=dakwah
S3_SECRET_ACCESS_KEY=change-this-storage-secret
S3_BUCKET=dakwah
S3_PUBLIC_URL=https://storage.example.com/dakwah
