APP_IMAGE=ghcr.io/aantriono82/dakwah:latest
APP_PUBLIC_URL=https://dakwah.example.com
CORS_ORIGINS=https://dakwah.example.com
AUTH_COOKIE_SECURE=true
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=https://dakwah.example.com/api/auth/google/callback
AUTH_CAPTCHA_PROVIDER=manual
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=9000
OPENAI_TIMEOUT_MS=30000
OPENAI_WEB_SEARCH_ENABLED=true
OPENAI_WEB_SEARCH_CONTEXT_SIZE=medium
WEB_RESEARCH_ENABLED=true
WEB_RESEARCH_SEARCH_ENABLED=true
WEB_RESEARCH_MAX_RESULTS=4
WEB_RESEARCH_TIMEOUT_MS=7000

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

RESEND_API_KEY=
EMAIL_FROM=Dakwah <noreply@example.com>

SEED_ADMIN_PASSWORD=change-this-admin-password
SEED_USER_PASSWORD=change-this-user-password

S3_ACCESS_KEY_ID=dakwah
S3_SECRET_ACCESS_KEY=change-this-storage-secret
S3_BUCKET=dakwah
S3_PUBLIC_URL=https://storage.example.com/dakwah
