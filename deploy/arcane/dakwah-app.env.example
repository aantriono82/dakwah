APP_IMAGE=ghcr.io/aantriono82/dakwah:latest

APP_PUBLIC_URL=https://dakwah.aantriono.com
CORS_ORIGINS=https://dakwah.aantriono.com
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_DOMAIN=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=https://dakwah.aantriono.com/api/auth/google/callback

AUTH_CAPTCHA_PROVIDER=manual
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

AI_PROVIDER=deepseek
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODELS=
OPENAI_BASE_URL=
OPENAI_MAX_TOKENS=5500
OPENAI_TIMEOUT_MS=30000
OPENAI_WEB_SEARCH_ENABLED=false
OPENAI_WEB_SEARCH_CONTEXT_SIZE=medium
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_MODELS=deepseek-v4-pro,deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MAX_TOKENS=9000
DEEPSEEK_TIMEOUT_MS=90000
WEB_RESEARCH_ENABLED=true
WEB_RESEARCH_SEARCH_ENABLED=true
WEB_RESEARCH_MAX_RESULTS=4
WEB_RESEARCH_TIMEOUT_MS=7000

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODELS=
GEMINI_MAX_TOKENS=9000
GEMINI_TIMEOUT_MS=30000

MYQURAN_ENABLED=true
MYQURAN_API_BASE_URL=https://api.myquran.com/v3
MYQURAN_TIMEOUT_MS=2500
MYQURAN_CACHE_TTL_SECONDS=2592000

RESEND_API_KEY=
EMAIL_FROM=Dakwah <noreply@aantriono.com>
RESET_PASSWORD_DEBUG_LINK=false

SEED_ADMIN_PASSWORD=change-this-admin-password
SEED_USER_PASSWORD=change-this-user-password

S3_ENDPOINT=http://dakwah-rustfs:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=dakwah
S3_SECRET_ACCESS_KEY=change-this-storage-secret
S3_BUCKET=dakwah
S3_PUBLIC_URL=https://dakwah-storage.aantriono.com/dakwah
S3_SIGNED_URL_EXPIRES=604800
S3_REQUIRED=true
