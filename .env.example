PORT=3000
DATABASE_URL=./data/khutbah-ai.sqlite
APP_PUBLIC_URL=http://localhost:3000
CORS_ORIGINS=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_DOMAIN=
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Opsional. Default: APP_PUBLIC_URL + /api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URL=
# Pilihan: manual, turnstile. Default manual agar tidak memuat iframe pihak ketiga.
AUTH_CAPTCHA_PROVIDER=manual
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
GENERATE_RATE_LIMIT_WINDOW_MS=60000
GENERATE_RATE_LIMIT_MAX=6
DEFAULT_DAILY_GENERATE_LIMIT=50
MYQURAN_ENABLED=true
MYQURAN_API_BASE_URL=https://api.myquran.com/v3
MYQURAN_TIMEOUT_MS=2500
MYQURAN_CACHE_TTL_SECONDS=2592000

# Pilih provider AI: openai atau deepseek.
# Untuk OpenRouter/custom OpenAI-compatible, gunakan AI_PROVIDER=openai dan isi OPENAI_BASE_URL.
AI_PROVIDER=deepseek

# OpenAI resmi. Jika kosong saat AI_PROVIDER=openai, aplikasi memakai generator fallback lokal.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Opsional: daftar model prioritas dipisah koma. Jika diisi, aplikasi mencoba model berurutan sebelum fallback lokal.
OPENAI_MODELS=
OPENAI_BASE_URL=
OPENAI_MAX_TOKENS=9000
OPENAI_TIMEOUT_MS=30000
# Aktif otomatis untuk OpenAI resmi. Set false untuk mematikan akses web search.
OPENAI_WEB_SEARCH_ENABLED=true
# Pilihan: low, medium, high. Semakin tinggi semakin banyak konteks web yang dipakai.
OPENAI_WEB_SEARCH_CONTEXT_SIZE=medium

# DeepSeek memakai adapter OpenAI-compatible. Dipakai saat AI_PROVIDER=deepseek.
# Jika DEEPSEEK_* kosong, aplikasi fallback ke OPENAI_* untuk kompatibilitas deployment lama.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_MODELS=deepseek-v4-pro,deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MAX_TOKENS=9000
DEEPSEEK_TIMEOUT_MS=90000

# Crawler/search backend untuk provider kompatibel seperti DeepSeek.
WEB_RESEARCH_ENABLED=true
WEB_RESEARCH_SEARCH_ENABLED=true
WEB_RESEARCH_MAX_RESULTS=4
WEB_RESEARCH_TIMEOUT_MS=7000

# Password seed hanya dipakai saat akun belum ada di database.
SEED_ADMIN_PASSWORD=change-this-admin-password
SEED_USER_PASSWORD=change-this-user-password

# Opsional untuk fitur lupa kata sandi. Jika kosong, link reset dicetak ke log server.
RESEND_API_KEY=
EMAIL_FROM=Dakwah <onboarding@resend.dev>
# Jangan aktifkan di production. Dipakai hanya untuk testing lokal agar API mengembalikan link reset.
RESET_PASSWORD_DEBUG_LINK=false

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=khutbahai
S3_SECRET_ACCESS_KEY=khutbahai-secret
S3_BUCKET=khutbahai
S3_PUBLIC_URL=http://localhost:9000/khutbahai
S3_SIGNED_URL_EXPIRES=604800
# Set true di deployment agar export gagal jelas jika upload storage bermasalah.
S3_REQUIRED=false
